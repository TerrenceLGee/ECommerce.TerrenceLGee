<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ECommerce.AvaloniaClient.TerrenceLGee.AddCategoryView"
			 xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
			 x:DataType="vm:AddCategoryViewModel">
	<ScrollViewer>
		<StackPanel Spacing="10" Margin="10">
			<StackPanel>
				<TextBlock Text="Add Category" 
						   Classes="Header"/>
			</StackPanel>
			<TextBlock Text="Name" 
					   Classes="Label"/>
			<TextBox Text="{Binding Name}"/>
			<TextBlock Classes="Error" 
					   Text="{Binding NameErrors}"/>

			<TextBlock Text="Description (optional)" 
					   Classes="Label"/>
			<TextBox Text="{Binding Description}"/>
			<TextBlock Classes="Error" 
					   Text="{Binding DescriptionErrors}"/>

			<Button Content="Add Category" 
					Command="{Binding AddCategoryCommand}" 
					Classes="Success"
					HorizontalAlignment="Center"
					Margin="0,10,0,0"/>
			<Button Content="Back" 
					Classes="Secondary"
					Command="{Binding GoBackCommand}" 
					HorizontalAlignment="Center"
					Margin="0,10,0,0"/>
			<TextBlock Text="{Binding SuccessMessage}" 
					   Classes="Success" 
					   IsVisible="{Binding !!SuccessMessage}"
					   HorizontalAlignment="Center"/>
			<TextBlock Text="{Binding ErrorMessage}" 
					   Classes="Error" 
					   IsVisible="{Binding !!ErrorMessage}"
					   HorizontalAlignment="Center"/>
		</StackPanel>
	</ScrollViewer>
</UserControl>
