<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ECommerce.AvaloniaClient.TerrenceLGee.AdminChooseProductForUpdateView"
			 xmlns:local="using:ECommerce.AvaloniaClient.TerrenceLGee"
			 xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
			 x:DataType="vm:AdminChooseProductForUpdateViewModel">
	<ScrollViewer>
		<StackPanel>
			<TextBlock Text="Choose A Product To Update" 
					   Classes="Header"/>
			<local:ProductsAdminBaseView DataContext="{Binding}"/>
			<StackPanel Orientation="Horizontal" 
						HorizontalAlignment="Center" 
						Spacing="10">
				<Button Content="Back To Product Page" 
						Classes="Secondary"
						Command="{Binding GoBackCommand}"/>
			</StackPanel>
		</StackPanel>
	</ScrollViewer>
</UserControl>
