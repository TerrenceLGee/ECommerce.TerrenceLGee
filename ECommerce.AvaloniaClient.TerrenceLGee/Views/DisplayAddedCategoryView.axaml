<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ECommerce.AvaloniaClient.TerrenceLGee.DisplayAddedCategoryView"
             xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
             x:DataType="vm:DisplayAddedCategoryViewModel">
  <StackPanel>
	  <TextBlock Text="Added Category" FontSize="36" FontWeight="ExtraBold" Margin="0,0,0,15"/>
      <Border Padding="15" CornerRadius="5" Background="#3a3a3a">
		  <StackPanel Spacing="10">
			  <WrapPanel>
				  <TextBlock Text="Name: " FontSize="24"/>
                  <TextBlock Text="{Binding Category.Name}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>
              <WrapPanel>
				  <TextBlock Text="Description: " FontSize="24"/>
                  <TextBlock Text="{Binding Category.Description}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>
              <WrapPanel>
				  <TextBlock Text="Created At: " FontSize="24"/>
                  <TextBlock Text="{Binding Category.CreatedAt}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>
              <StackPanel>
				  <Button Content="Add Another Category" Command="{Binding GoBackCommand}"
                      HorizontalAlignment="Center" Margin="0,0,0,15"/>
                  <Button Content="Back To Category Page" Command="{Binding GoBackToPreviousPageCommand}"
                          HorizontalAlignment="Center" Margin="0,0,0,15"/>
              </StackPanel>
          </StackPanel>
      </Border>
  </StackPanel>
</UserControl>
