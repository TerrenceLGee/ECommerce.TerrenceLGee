<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ECommerce.AvaloniaClient.TerrenceLGee.DisplayAdminProductView"
			 xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
			 x:DataType="vm:DisplayAdminProductViewModel">
	<ScrollViewer>
		<StackPanel>
			<TextBlock Text="{Binding Product.Name}"
					   Foreground="Goldenrod"
					   TextDecorations="Underline"
					   FontSize="24"
					   FontWeight="ExtraBold"
					   Margin="0,0,0,15"/>
			<Border Padding="15"
					CornerRadius="5">
				<StackPanel Spacing="10">
					<WrapPanel>
						<TextBlock Text="Category Name: "
								   Foreground="LightCyan"
								   FontStyle="Italic"
								   FontSize="15"/>
						<TextBlock Text="{Binding Product.CategoryName}"
								   Foreground="LightGoldenrodYellow"
								   FontWeight="ExtraBold"
								   FontSize="15"
								   TextWrapping="Wrap"/>
					</WrapPanel>

					<WrapPanel>
						<TextBlock Text="Product Description: "
								   Foreground="LightCyan"
								   FontStyle="Italic"
								   FontSize="15"/>
						<TextBlock Text="{Binding Product.Description}"
								   Foreground="LightGoldenrodYellow"
								   FontWeight="ExtraBold"
								   FontSize="15"
								   TextWrapping="Wrap"/>
					</WrapPanel>

					<WrapPanel>
						<TextBlock Text="Stock Quantity: "
								   Foreground="LightCyan"
								   FontStyle="Italic"
								   FontSize="15"/>
						<TextBlock Text="{Binding Product.StockQuantity}"
								   Foreground="LightGoldenrodYellow"
								   FontWeight="ExtraBold"
								   FontSize="15"
								   TextWrapping="Wrap"/>
					</WrapPanel>

					<WrapPanel>
						<TextBlock Text="Unit Price: "
								   Foreground="LightCyan"
								   FontStyle="Italic"
								   FontSize="15"/>
						<TextBlock Text="{Binding Product.UnitPrice}"
								   Foreground="LightGoldenrodYellow"
								   FontWeight="ExtraBold"
								   FontSize="15"
								   TextWrapping="Wrap"/>
					</WrapPanel>

					<WrapPanel>
						<TextBlock Text="Discount Percentage: "
								   Foreground="LightCyan"
								   FontStyle="Italic"
								   FontSize="15"/>
						<TextBlock Text="{Binding Product.DiscountPercentage}"
								   Foreground="LightGoldenrodYellow"
								   FontWeight="ExtraBold"
								   FontSize="15"
								   TextWrapping="Wrap"/>
					</WrapPanel>

					<WrapPanel>
						<TextBlock Text="In Stock?: "
								   Foreground="LightCyan"
								   FontStyle="Italic"
								   FontSize="15"/>
						<TextBlock Text="{Binding Product.IsInStock}"
								   Foreground="LightGoldenrodYellow"
								   FontWeight="ExtraBold"
								   FontSize="15"
								   TextWrapping="Wrap"/>
					</WrapPanel>

					<WrapPanel>
						<TextBlock Text="Is Deleted?: "
								   Foreground="LightCyan"
								   FontStyle="Italic"
								   FontSize="15"/>
						<TextBlock Text="{Binding Product.IsDeleted}"
								   Foreground="LightGoldenrodYellow"
								   FontWeight="ExtraBold"
								   FontSize="15"
								   TextWrapping="Wrap"/>
					</WrapPanel>

					<WrapPanel>
						<TextBlock Text="Created At: "
								   Foreground="LightCyan"
								   FontStyle="Italic"
								   FontSize="15"/>
						<TextBlock Text="{Binding Product.CreatedAt}"
								   Foreground="LightGoldenrodYellow"
								   FontWeight="ExtraBold"
								   FontSize="15"
								   TextWrapping="Wrap"/>
					</WrapPanel>

					<WrapPanel>
						<TextBlock Text="Updated At: "
								   Foreground="LightCyan"
								   FontStyle="Italic"
								   FontSize="15"/>
						<TextBlock Text="{Binding Product.UpdatedAt}"
								   Foreground="LightGoldenrodYellow"
								   FontWeight="ExtraBold"
								   FontSize="15"
								   TextWrapping="Wrap"/>
					</WrapPanel>
				</StackPanel>
			</Border>
			<StackPanel>
				<Button Content="Back"
						Command="{Binding GoBackCommand}"
						HorizontalAlignment="Center"
						Margin="0,0,0,15"/>
			</StackPanel>
		</StackPanel>
	</ScrollViewer>
</UserControl>
