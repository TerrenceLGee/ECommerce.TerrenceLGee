<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ECommerce.AvaloniaClient.TerrenceLGee.DisplayAdminProductView"
             xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
             x:DataType="vm:DisplayAdminProductViewModel">
  <StackPanel>
	  <TextBlock Text="{Binding Product.Name}" FontSize="36" FontWeight="ExtraBold" Margin="0,0,0,15"/>
      <Border Padding="15" CornerRadius="5" Background="#3a3a3a">
		  <StackPanel Spacing="10">
              <WrapPanel>
				  <TextBlock Text="Category Name: " FontSize="24"/>
                  <TextBlock Text="{Binding Product.CategoryName}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>

              <WrapPanel>
				  <TextBlock Text="Product Description: " FontSize="24"/>
                  <TextBlock Text="{Binding Product.Description}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>

              <WrapPanel>
				  <TextBlock Text="Stock Quantity: " FontSize="24"/>
                  <TextBlock Text="{Binding Product.StockQuantity}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>

              <WrapPanel>
				  <TextBlock Text="Unit Price: " FontSize="24"/>
                  <TextBlock Text="{Binding Product.UnitPrice}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>

              <WrapPanel>
				  <TextBlock Text="Discount Percentage: " FontSize="24"/>
                  <TextBlock Text="{Binding Product.DiscountPercentage}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>

              <WrapPanel>
				  <TextBlock Text="In Stock?: " FontSize="24"/>
                  <TextBlock Text="{Binding Product.IsInStock}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>

              <WrapPanel>
				  <TextBlock Text="Is Deleted?: " FontSize="24"/>
                  <TextBlock Text="{Binding Product.IsDeleted}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>

              <WrapPanel>
				  <TextBlock Text="Created At: " FontSize="24"/>
                  <TextBlock Text="{Binding Product.CreatedAt}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>

              <WrapPanel>
				  <TextBlock Text="Updated At: " FontSize="24"/>
                  <TextBlock Text="{Binding Product.UpdatedAt}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>

              <Button Content="Back" Command="{Binding GoBackCommand}"
                      HorizontalAlignment="Center" Margin="0,0,0,15"/>
          </StackPanel>
      </Border>
  </StackPanel>
</UserControl>
