<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ECommerce.AvaloniaClient.TerrenceLGee.DisplayCustomerAddressForAdminView"
             xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
             x:DataType="vm:DisplayCustomerAddressForAdminViewModel">
  <StackPanel>
	  <TextBlock Text="Address Information" FontSize="36" FontWeight="ExtraBold" Margin="0,0,0,15"/>
      <Border Padding="15" CornerRadius="5" Background="#3a3a3a">
		  <StackPanel Spacing="10">
              <WrapPanel>
				  <TextBlock Text="Customer Id: " FontSize="24"/>
                  <TextBlock Text="{Binding Address.CustomerId}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>
              <WrapPanel>
				  <TextBlock Text="Address Line 1: " FontSize="24"/>
                  <TextBlock Text="{Binding Address.AddressLine1}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>
              <WrapPanel>
				  <TextBlock Text="Address Line 2: " FontSize="24"/>
                  <TextBlock Text="{Binding Address.AddressLine2}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>
              <WrapPanel>
				  <TextBlock Text="City: " FontSize="24"/>
                  <TextBlock Text="{Binding Address.City}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>
              <WrapPanel>
				  <TextBlock Text="State: " FontSize="24"/>
                  <TextBlock Text="{Binding Address.State}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>
              <WrapPanel>
				  <TextBlock Text="Postal Code: " FontSize="24"/>
                  <TextBlock Text="{Binding Address.PostalCode}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>
              <WrapPanel>
				  <TextBlock Text="Country: " FontSize="24"/>
                  <TextBlock Text="{Binding Address.Country}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>
              <WrapPanel>
				  <TextBlock Text="Is Billing Address? " FontSize="24"/>
                  <TextBlock Text="{Binding Address.IsBillingAddress}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>
              <WrapPanel>
				  <TextBlock Text="Is Shipping Address? " FontSize="24"/>
                  <TextBlock Text="{Binding Address.IsShippingAddress}" FontWeight="ExtraBold" FontSize="24" TextWrapping="Wrap"/>
              </WrapPanel>
              <Button Content="Go Back To Customer Addresses" Command="{Binding GoBackCommand}" 
                      HorizontalAlignment="Center" Margin="0,0,0,15"/>
          </StackPanel>
      </Border>
  </StackPanel>
</UserControl>
