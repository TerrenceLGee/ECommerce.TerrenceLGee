<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ECommerce.AvaloniaClient.TerrenceLGee.DisplayOrderDetailsView"
             xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
             x:DataType="vm:DisplayOrderDetailsViewModel">
  <ScrollViewer>
	  <Grid RowDefinitions="Auto, Auto, Auto, Auto" Margin="10">
		  <StackPanel Grid.Row="0">
			  <WrapPanel>
				  <TextBlock Text="Order For: " FontSize="36" FontWeight="ExtraBold" Margin="0,0,0,15"/>
                  <TextBlock Text="{Binding Sale.CustomerName}" FontSize ="36" FontWeight="ExtraBold" Margin="0,0,0,15"/>
              </WrapPanel>
              <Border Padding="15" CornerRadius="5" Background="#3a3a3a">
				  <StackPanel Spacing="10">
					  <WrapPanel>
						  <TextBlock Text="Subtotal: " FontSize="24" FontWeight="ExtraBold"/>
                          <TextBlock Text="{Binding Sale.TotalBaseAmount, StringFormat={}{0:C}}" FontSize="24" FontWeight="ExtraBold" TextWrapping="Wrap"/>
                      </WrapPanel>
                      <WrapPanel>
						  <TextBlock Text="Total Discount: " FontSize="24" FontWeight="ExtraBold"/>
                          <TextBlock Text="{Binding Sale.TotalDiscountAmount, StringFormat={}{0:C}}" FontSize="24" FontWeight="ExtraBold" TextWrapping="Wrap"/>
                      </WrapPanel>
                      <WrapPanel>
						  <TextBlock Text="Total Amount: " FontSize="24" FontWeight="ExtraBold"/>
                          <TextBlock Text="{Binding Sale.TotalAmount, StringFormat={}{0:C}}" FontSize="24" FontWeight="ExtraBold" TextWrapping="Wrap"/>
                      </WrapPanel>
                      <WrapPanel>
						  <TextBlock Text="Order Date: " FontSize="24" FontWeight="ExtraBold"/>
                          <TextBlock Text="{Binding Sale.CreatedAt}" FontSize="24" FontWeight="ExtraBold" TextWrapping="Wrap"/>
                      </WrapPanel>
                      <WrapPanel>
						  <TextBlock Text="Order Status: " FontSize="24" FontWeight="ExtraBold"/>
                          <TextBlock Text="{Binding Sale.SaleStatus}" FontSize="24" FontWeight="ExtraBold" TextWrapping="Wrap"/>
                      </WrapPanel>
                  </StackPanel>
              </Border>
          </StackPanel>
          <StackPanel Grid.Row="1">
			  <TextBlock Text="Items Ordered" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
              <DataGrid ItemsSource="{Binding OrderItemsForDisplay}"
                        IsReadOnly="True"
                        GridLinesVisibility="All"
                        BorderThickness="1"
                        BorderBrush="Gray">
                  <DataGrid.Columns>
					  <DataGridTextColumn Header="Name" Binding="{Binding ProductName}" Width="Auto"/>
                      <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="Auto"/>
                      <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:C}}" Width="Auto"/>
                      <DataGridTextColumn Header="Discount" Binding="{Binding Discount, StringFormat={}{0:C}}" Width="Auto"/>
                      <DataGridTextColumn Header="Total Price" Binding="{Binding TotalPrice, StringFormat={}{0:C}}" Width="Auto"/>
                  </DataGrid.Columns>
              </DataGrid>
          </StackPanel>
          <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,0,0,10">
			  <Button Content="Previous" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding HasPreviousPage}"/>
              <TextBlock>
				  <Run Text="{Binding Page}"/>
                  <Run Text=" of "/>
                  <Run Text="{Binding TotalPages}"/>
              </TextBlock>
              <Button Content="Next" Command="{Binding NextPageCommand}" IsEnabled="{Binding HasNextPage}"/>
          </StackPanel>
          <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
			  <Button Content="Shop Again" Command="{Binding ShopAgainCommand}"/>
          </StackPanel>
      </Grid>
  </ScrollViewer>
</UserControl>
