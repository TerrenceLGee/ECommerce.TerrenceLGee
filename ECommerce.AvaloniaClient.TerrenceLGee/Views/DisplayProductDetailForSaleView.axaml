<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ECommerce.AvaloniaClient.TerrenceLGee.DisplayProductDetailForSaleView"
             xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
             x:DataType="vm:DisplayProductDetailForSaleViewModel">
  <Grid RowDefinitions="Auto, Auto, Auto" Margin="10">
	  <StackPanel Grid.Row="0">
		  <TextBlock Text="{Binding Product.Name}" FontSize="36" FontWeight="ExtraBold" Margin="0,0,0,15"/>
      </StackPanel>
  </Grid>
</UserControl>
