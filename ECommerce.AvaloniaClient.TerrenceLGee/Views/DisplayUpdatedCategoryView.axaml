<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ECommerce.AvaloniaClient.TerrenceLGee.DisplayUpdatedCategoryView"
			 xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
			 x:DataType="vm:DisplayUpdatedCategoryViewModel">
	<StackPanel>
		<TextBlock Text="Updated Category"
				   FontSize="24"
				   FontWeight="ExtraBold"
				   Foreground="Goldenrod"
				   TextDecorations="Underline"
				   Margin="0,0,0,15"/>
		<Border Padding="15"
				CornerRadius="5">
			<StackPanel Spacing="10">
				<WrapPanel>
					<TextBlock Text="Name: "
							   Foreground="LightCyan"
							   FontStyle="Italic"
							   FontSize="15"/>
					<TextBlock Text="{Binding Category.Name}"
							   Foreground="LightGoldenrodYellow"
							   FontWeight="ExtraBold"
							   FontSize="15"
							   TextWrapping="Wrap"/>
				</WrapPanel>
				<WrapPanel>
					<TextBlock Text="Description: "
							   Foreground="LightCyan"
							   FontStyle="Italic"
							   FontSize="15"/>
					<TextBlock Text="{Binding Category.Description}"
							   Foreground="LightGoldenrodYellow"
							   FontWeight="ExtraBold"
							   FontSize="15"
							   TextWrapping="Wrap"/>
				</WrapPanel>
				<WrapPanel>
					<TextBlock Text="Created At: "
							   Foreground="LightCyan"
							   FontStyle="Italic"
							   FontSize="15"/>
					<TextBlock Text="{Binding Category.CreatedAt}"
							   Foreground="LightGoldenrodYellow"
							   FontWeight="ExtraBold"
							   FontSize="15"
							   TextWrapping="Wrap"/>
				</WrapPanel>
				<WrapPanel>
					<TextBlock Text="Updated At: "
							   Foreground="LightCyan"
							   FontStyle="Italic"
							   FontSize="15"/>
					<TextBlock Text="{Binding Category.UpdatedAt}"
							   Foreground="LightGoldenrodYellow"
							   FontWeight="ExtraBold"
							   FontSize="15"
							   TextWrapping="Wrap"/>
				</WrapPanel>
			</StackPanel>
		</Border>
		<StackPanel>
			<Button Content="Update Another Category"
					Command="{Binding GoBackCommand}"
					HorizontalAlignment="Center"
					Margin="0,0,0,15"/>
			<Button Content="Back To Category Page"
					Command="{Binding GoBackToCategoryPageCommand}"
					HorizontalAlignment="Center"
					Margin="0,0,0,15"/>
		</StackPanel>
	</StackPanel>
</UserControl>
