<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ECommerce.AvaloniaClient.TerrenceLGee.HomeScreenView"
			 xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
			 x:DataType="vm:HomeScreenViewModel">
	<ScrollViewer>
		<Grid RowDefinitions="Auto, Auto" Margin="10">
			<StackPanel Grid.Row="0">
				<Image Source="/Assets/home.jpg" Height="600" Width="1000"/>
			</StackPanel>
		</Grid>
	</ScrollViewer>
</UserControl>
