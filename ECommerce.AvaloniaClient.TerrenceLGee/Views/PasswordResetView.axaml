<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ECommerce.AvaloniaClient.TerrenceLGee.PasswordResetView"
             xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
             x:DataType="vm:PasswordResetViewModel">
  <UserControl.Styles>
	  <Style Selector="TextBlock.Error">
		  <Setter Property="Foreground" Value="Red"/>
          <Setter Property="FontSize" Value="12"/>
          <Setter Property="Margin" Value="0,0,0,5"/>
      </Style>
  </UserControl.Styles>

    <ScrollViewer>
		<Grid RowDefinitions="Auto, Auto, Auto, Auto" 
              Margin="10">
			<StackPanel Grid.Row="0" 
                        HorizontalAlignment="Center">
				<TextBlock Text="Reset Password" 
                           FontWeight="ExtraBold" 
                           FontSize="24" 
                           TextDecorations="Underline" 
                           Foreground="Goldenrod"/>
            </StackPanel>
            <StackPanel Grid.Row="1" 
                        Spacing="5" 
                        Margin="10">
				<TextBlock Text="Email Address" 
                           FontWeight="ExtraBold" 
                           HorizontalAlignment="Center"/>
                <TextBox Text="{Binding Email}" 
                         HorizontalAlignment="Center" 
                         Width="400"/>
                <TextBlock Classes="Error" 
                           Text="{Binding EmailErrors}"/>

                <TextBlock Text="Previous Password" 
                           FontWeight="ExtraBold" 
                           HorizontalAlignment="Center"/>
                <TextBox Text="{Binding OldPassword}"
                         PasswordChar="*"
                         HorizontalAlignment="Center" 
                         Width="400"/>
                <TextBlock Classes="Error" 
                           Text="{Binding OldPasswordErrors}"/>

                <TextBlock Text="New Password" 
                           FontWeight="ExtraBold" 
                           HorizontalAlignment="Center"/>
                <TextBox Text="{Binding NewPassword}" 
                         PasswordChar="*"
                         HorizontalAlignment="Center" 
                         Width="400"/>
                <TextBlock Classes="Error" 
                           Text="{Binding NewPasswordErrors}"/>

                <TextBlock Text="Confirm New Password" 
                           FontWeight="ExtraBold" 
                           HorizontalAlignment="Center"/>
                <TextBox Text="{Binding ResetConfirmPassword}" 
                         PasswordChar="*"
                         HorizontalAlignment="Center" Width="400"/>
                <TextBlock Classes="Error" 
                           Text="{Binding ResetConfirmPasswordErrors}"/>
            </StackPanel>
            <StackPanel Grid.Row="2" 
                        HorizontalAlignment="Center" 
                        Orientation="Vertical">
				<Button Content="Reset Password" 
                        Command="{Binding ResetPasswordCommand}" 
                        HorizontalAlignment="Center" 
                        Margin="0,10,0,0"/>
                <Button Content="Back" 
                        Command="{Binding GoBackCommand}" 
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0"/>
            </StackPanel>
            <StackPanel Grid.Row="3"
                        HorizontalAlignment="Center">
                <TextBlock Text="{Binding SuccessMessage}" 
                           Foreground="Gold"
                           IsVisible="{Binding SuccessMessage}"
                           HorizontalAlignment="Center"/>
                <TextBlock Classes="Error" Text="{Binding ErrorMessage}"
                           IsVisible="{Binding ErrorMessage}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
