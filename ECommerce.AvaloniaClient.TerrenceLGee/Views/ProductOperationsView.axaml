<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ECommerce.AvaloniaClient.TerrenceLGee.ProductOperationsView"
             xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
             x:DataType="vm:ProductOperationsViewModel">
  <ScrollViewer>
	  <Grid RowDefinitions="Auto, Auto, Auto">
		  <StackPanel Grid.Row="0">
			  <Image Source="/Assets/products.jpg" Height="600" Width="600"/>
          </StackPanel>
          <StackPanel Grid.Row="1" HorizontalAlignment="Center" Spacing="30" Orientation="Horizontal">
			  <Button Content="View Products" Command="{Binding ViewProductsCommand}"/>
              <Button Content="Add New Product" Command="{Binding AddProductCommand}"/>
              <Button Content="Update Product" Command="{Binding UpdateProductCommand}"/>
              <Button Content="Restore Product" Command="{Binding RestoreProductCommand}"/>
              <Button Content="Delete Product" Command="{Binding DeleteProductCommand}"/>
          </StackPanel>
      </Grid>
  </ScrollViewer>
</UserControl>
