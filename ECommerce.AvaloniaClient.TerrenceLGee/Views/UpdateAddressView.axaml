<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ECommerce.AvaloniaClient.TerrenceLGee.UpdateAddressView"
             xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
             x:DataType="vm:UpdateAddressViewModel">
  <UserControl.Styles>
	  <Style Selector="TextBlock.Error">
		  <Setter Property="Foreground" Value="Red"/>
          <Setter Property="FontSize" Value="12"/>
          <Setter Property="Margin" Value="0,0,0,5"/>
      </Style>
  </UserControl.Styles>

    <Border Padding="20" CornerRadius="5" Background="#2d2d2d">
		<TabControl>
			<TabItem Header="Update Address">
				<ScrollViewer>
					<StackPanel Spacing="10" Margin="10">
						<TextBlock Text="Address Line 1" FontWeight="ExtraBold"/>
                        <TextBox Text="{Binding AddressLine1}"/>
                        <TextBlock Classes="Error" Text="{Binding AddressLine1Errors}"/>

                        <TextBlock Text="Address Line 2" FontWeight="ExtraBold"/>
                        <TextBox Text="{Binding AddressLine2}"/>
                        <TextBlock Classes="Error" Text="{Binding AddressLine2Errors}"/>

                        <TextBlock Text="City" FontWeight="ExtraBold"/>
                        <TextBox Text="{Binding City}"/>
                        <TextBlock Classes="Error" Text="{Binding CityErrors}"/>

                        <TextBlock Text="State" FontWeight="ExtraBold"/>
                        <TextBox Text="{Binding State}"/>
                        <TextBlock Classes="Error" Text="{Binding StateErrors}"/>

                        <TextBlock Text="Postal Code" FontWeight="ExtraBold"/>
                        <TextBox Text="{Binding PostalCode}"/>
                        <TextBlock Classes="Error" Text="{Binding PostalCodeErrors}"/>

                        <TextBlock Text="Country" FontWeight="ExtraBold"/>
                        <TextBox Text="{Binding Country}"/>
                        <TextBlock Classes="Error" Text="{Binding CountryErrors}"/>

                        <CheckBox IsChecked="{Binding IsBillingAddress}" Content="Is Billing Address?"/>
                        <CheckBox IsChecked="{Binding IsShippingAddress}" Content="Is Shipping Address?"/>
                        
                        <StackPanel>
							<Button Content="Update Address" Command="{Binding UpdateAddressCommand}"
                                    HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding SuccessMessage}" Foreground="Gold" IsVisible="{Binding SuccessMessage}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ErrorMessage}" Classes="Error" IsVisible="{Binding !!ErrorMessage}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Border>
</UserControl>
