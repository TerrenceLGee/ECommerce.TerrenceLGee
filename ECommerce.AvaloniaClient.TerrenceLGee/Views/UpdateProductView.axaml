<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ECommerce.AvaloniaClient.TerrenceLGee.UpdateProductView"
			 xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
			 x:DataType="vm:UpdateProductViewModel">
	<ScrollViewer>
		<Border Padding="20" CornerRadius="5" Background="#2d2d2d">
			<StackPanel Spacing="10" Margin="10">
				<StackPanel>
					<TextBlock Text="Update Product" Classes="Header"/>
				</StackPanel>
				<TextBlock Text="Name" 
						   Classes="Label"/>
				<TextBox Text="{Binding Name}"/>
				<TextBlock Classes="Error" 
						   Text="{Binding NameErrors}"/>

				<TextBlock Text="Description (optional)" 
						   Classes="Label"/>
				<TextBox Text="{Binding Description}"/>
				<TextBlock Classes="Error" 
						   Text="{Binding DescriptionErrors}"/>

				<TextBlock Text="Stock Quantity" 
						   Classes="Label"/>
				<TextBox Text="{Binding StockQuantity}"/>
				<TextBlock Classes="Error" 
						   Text="{Binding StockQuantityErrors}"/>

				<TextBlock Text="Discount Percentage" 
						   Classes="Label"/>
				<TextBox Text="{Binding DiscountPercentage}"/>
				<TextBlock Classes="Error" 
						   Text="{Binding DiscountPercentageErrors}"/>

				<TextBlock Text="Image Url" 
						   Classes="Label"/>
				<TextBox Text="{Binding ImageUrl}"/>
				<TextBlock Classes="Error" 
						   Text="{Binding ImageUrlErrors}"/>

				<CheckBox IsChecked="{Binding IsInStock}" 
						  Content="In Stock?"/>
				<CheckBox IsChecked="{Binding IsDeleted}" 
						  Content="Deleted?"/>

				<Button Content="Update Product" 
						Command="{Binding UpdateProductCommand}" 
						HorizontalAlignment="Center"
						Margin="0,10,0,0"/>
				<TextBlock Text="{Binding SuccessMessage}" 
						   Foreground="Gold" 
						   IsVisible="{Binding !!SuccessMessage}"
						   HorizontalAlignment="Center"/>
				<TextBlock Text="{Binding ErrorMessage}" 
						   Classes="Error" 
						   IsVisible="{Binding !!ErrorMessage}"
						   HorizontalAlignment="Center"/>
				<StackPanel>
					<Button Content="Back" 
							Classes="Secondary"
							Command="{Binding GoBackCommand}" 
							HorizontalAlignment="Center"
							Margin="0,10,0,0"/>
				</StackPanel>
			</StackPanel>
		</Border>
	</ScrollViewer>
</UserControl>
