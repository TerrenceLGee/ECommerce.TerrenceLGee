<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ECommerce.AvaloniaClient.TerrenceLGee.UpdateProductView"
             xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
             x:DataType="vm:UpdateProductViewModel">
  <UserControl.Styles>
	  <Style Selector="TextBlock.Error">
		  <Setter Property="Foreground" Value="Red"/>
          <Setter Property="FontSize" Value="12"/>
          <Setter Property="Margin" Value="0,0,0,5"/>
      </Style>
  </UserControl.Styles>

    <Border Padding="20" CornerRadius="5" Background="#2d2d2d">
		<TabControl>
			<TabItem Header="Update Product">
				<StackPanel Spacing="10" Margin="10">
					<TextBlock Text="Name" FontWeight="ExtraBold"/>
                    <TextBox Text="{Binding Name}"/>
                    <TextBlock Classes="Error" Text="{Binding NameErrors}"/>

                    <TextBlock Text="Description (optional)" FontWeight="ExtraBold"/>
                    <TextBox Text="{Binding Description}"/>
                    <TextBlock Classes="Error" Text="{Binding DescriptionErrors}"/>

                    <TextBlock Text="Stock Quantity" FontWeight="ExtraBold"/>
                    <TextBox Text="{Binding StockQuantity}"/>
                    <TextBlock Classes="Error" Text="{Binding StockQuantityErrors}"/>

                    <TextBlock Text="Discount Percentage" FontWeight="ExtraBold"/>
                    <TextBox Text="{Binding DiscountPercentage}"/>
                    <TextBlock Classes="Error" Text="{Binding DiscountPercentageErrors}"/>

                    <CheckBox IsChecked="{Binding IsInStock}" Content="In Stock?"/>
                    <CheckBox IsChecked="{Binding IsDeleted}" Content="Deleted?"/>

                    <Button Content="Update Product" Command="{Binding UpdateProductCommand}" HorizontalAlignment="Center"
                            Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="Gold" IsVisible="{Binding !!SuccessMessage}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}" Classes="Error" IsVisible="{Binding !!ErrorMessage}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Border>
</UserControl>
