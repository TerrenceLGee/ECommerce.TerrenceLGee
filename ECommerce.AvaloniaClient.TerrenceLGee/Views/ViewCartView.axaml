<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:orderdtos="using:ECommerce.Shared.TerrenceLGee.DTOs.OrderDTOs"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ECommerce.AvaloniaClient.TerrenceLGee.ViewCartView"
			 xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
			 x:DataType="vm:ViewCartViewModel">
	<ScrollViewer>
		<Grid RowDefinitions="Auto, Auto, Auto" 
			  Margin="10">
			<StackPanel Grid.Row="0">
				<TextBlock Text="Shopping Cart" 
						   Classes="Header"/>
				<TextBlock Text="You can remove an item by selecting it and pressing the remove item button"
						   Classes="Header"/>
				<StackPanel>
					<DataGrid ItemsSource="{Binding CartForDisplay}"
							  SelectedItem="{Binding SelectedItem}"
							  IsReadOnly="False">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Item " 
												Binding="{Binding ProductName}" 
												Width="Auto"/>
							<DataGridTextColumn Header="Total Price" 
												Binding="{Binding TotalAmount, StringFormat={}{0:C}}" 
												Width="Auto"/>
							<DataGridTemplateColumn Header="Quantity">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate DataType="orderdtos:CartItemDto">
										<TextBlock Text="{Binding Quantity}"
												   VerticalAlignment="Center"
												   Margin="5,0"/>
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
								<DataGridTemplateColumn.CellEditingTemplate>
									<DataTemplate DataType="orderdtos:CartItemDto">
										<NumericUpDown Value="{Binding Quantity}"
													   Minimum="1" Maximum="5000"
													   HorizontalAlignment="Stretch"/>
									</DataTemplate>
								</DataGridTemplateColumn.CellEditingTemplate>
							</DataGridTemplateColumn>
						</DataGrid.Columns>
					</DataGrid>
					<StackPanel Orientation="Horizontal" 
								HorizontalAlignment="Center" 
								Spacing="10" 
								Margin="0,0,0,10">
						<Button Content="Previous" 
								Command="{Binding PreviousPageCommand}" 
								IsEnabled="{Binding HasNextPage}"/>
						<TextBlock>
							<Run Text="{Binding Page}"/>
							<Run Text=" of "/>
							<Run Text="{Binding TotalPages}"/>
						</TextBlock>
						<Button Content="Next" 
								Command="{Binding NextPageCommand}" 
								IsEnabled="{Binding HasNextPage}"/>
					</StackPanel>
				</StackPanel>
			</StackPanel>
			<StackPanel Grid.Row="1">
				<Button Content="Clear Cart" 
						Command="{Binding ClearCartCommand}" 
						Classes="Danger"/> 
				<Button Content="Update Item Quantity" 
						Command="{Binding UpdateQuantityCommand}"/>
				<Button Content="Remove Item" 
						Command="{Binding RemoveItemCommand}"/>
				<Button Content="Checkout" 
						Command="{Binding CheckoutCommand}"/>
				<Button Content="Back" 
						Command="{Binding GoBackCommand}" 
						Classes="Secondary"/>
			</StackPanel>
			<StackPanel Grid.Row="2">
				<TextBlock Text="{Binding ErrorMessage}" 
						   Classes="Error" 
						   IsVisible="{Binding ErrorMessage}"
						   HorizontalAlignment="Center"/>
			</StackPanel>
		</Grid>
	</ScrollViewer>
</UserControl>
