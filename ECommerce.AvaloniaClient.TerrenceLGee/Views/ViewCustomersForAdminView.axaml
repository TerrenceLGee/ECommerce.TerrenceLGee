<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ECommerce.AvaloniaClient.TerrenceLGee.ViewCustomersForAdminView"
             xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
             x:DataType="vm:ViewCustomersForAdminViewModel">
  <ScrollViewer>
	  <Grid RowDefinitions="Auto, Auto, Auto, Auto" Margin="10">
		  <StackPanel Grid.Row="0">
			  <TextBlock Text="Filter By Number Of Orders Placed" FontWeight="ExtraBold"/>
              <StackPanel Orientation="Horizontal" Spacing="10">
				  <TextBox Text="{Binding MinSaleCount}" Watermark="Min Orders Placed..." Width="150"/>
                  <TextBox Text="{Binding MaxSaleCount}" Watermark="Max Orders Placed..." Width="150"/>
              </StackPanel>
              <TextBlock Text="Filter By Total Amount Spent" FontWeight="ExtraBold"/>
              <StackPanel Orientation="Horizontal" Spacing="10">
				  <TextBox Text="{Binding MinTotalSpent}" Watermark="Min Total Spent..." Width="150"/>
                  <TextBox Text="{Binding MaxTotalSpent}" Watermark="Max Total Spent..." Width="150"/>
              </StackPanel>
              <Button Content="Apply Filters" Command="{Binding LoadCustomersCommand}"/>
              <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}"/>
          </StackPanel>
          <StackPanel Grid.Row="1">
			  <TextBlock Text="Customers (Select a customer to see more information)" FontWeight="ExtraBold"/>
              <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}"/>
              <StackPanel>
				  <DataGrid ItemsSource="{Binding Customers}"
                            SelectedItem="{Binding SelectedCustomer}"
                            IsReadOnly="True"
                            GridLinesVisibility="All"
                            BorderThickness="1"
                            BorderBrush="Gray">
                      <DataGrid.Columns>
						  <DataGridTextColumn Header="Id" Binding="{Binding CustomerId}" Width="Auto"/>
						  <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="Auto"/>
						  <DataGridTextColumn Header="Last Name" Binding="{Binding LastName}" Width="Auto"/>
						  <DataGridTextColumn Header="Email Address" Binding="{Binding EmailAddress}" Width="Auto"/>
						  <DataGridTextColumn Header="Date Of Birth" Binding="{Binding DateOfBirth}" Width="Auto"/>
						  <DataGridTextColumn Header="Date Of Registration" Binding="{Binding RegistrationDate}" Width="Auto"/>
                      </DataGrid.Columns>
                  </DataGrid>
              </StackPanel>
              <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
				  <Button Content="Previous" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding HasPreviousPage}"/>
                  <TextBlock>
					  <Run Text="{Binding Page}"/>
                      <Run Text=" of "/>
                      <Run Text="{Binding TotalPages}"/>
                  </TextBlock>
                  <Button Content="Next" Command="{Binding NextPageCommand}" IsEnabled="{Binding HasNextPage}"/>
              </StackPanel>
          </StackPanel>
          <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
			  <Button Content="Back To Customer Page" Command="{Binding GoBackCommand}"/>
          </StackPanel>
      </Grid>
  </ScrollViewer>
</UserControl>
