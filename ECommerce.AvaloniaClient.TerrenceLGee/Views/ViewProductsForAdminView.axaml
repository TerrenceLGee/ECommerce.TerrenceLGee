<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ECommerce.AvaloniaClient.TerrenceLGee.ViewProductsForAdminView"
             xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
             x:DataType="vm:ViewProductsForAdminViewModel">
  <ScrollViewer>
	  <Grid RowDefinitions="Auto, Auto, Auto" Margin="10">
		  <StackPanel Grid.Row="0">
			  <TextBlock Text="Filter By Price Range" FontWeight="ExtraBold"/>
              <StackPanel Orientation="Horizontal" Spacing="10">
				  <TextBox Text="{Binding MinUnitPrice}" Watermark="Min Unit Price..." Width="150"/>
                  <TextBox Text="{Binding MaxUnitPrice}" Watermark="Max Unit Price..." Width="150"/>
              </StackPanel>
              <TextBlock Text="Filter By Stock Quantity Range" FontWeight="ExtraBold"/>
              <StackPanel Orientation="Horizontal" Spacing="10">
				  <TextBox Text="{Binding MinStockQuantity}" Watermark="Min Stock Quantity..." Width="150"/>
                  <TextBox Text="{Binding MaxStockQuantity}" Watermark="Max Stock Quantity..." Width="150"/>
              </StackPanel>
              <TextBlock Text="Filter By Discount Percentage" FontWeight="ExtraBold"/>
              <StackPanel Orientation="Horizontal" Spacing="10">
				  <TextBox Text="{Binding MinDiscountPercentage}" Watermark="Min Discount Percentage..." Width="150"/>
                  <TextBox Text="{Binding MaxDiscountPercentage}" Watermark="Max Discount Percentage..." Width="150"/>
              </StackPanel>
              <TextBlock Text="Filter By Category Name and/or filter on words/letters contained in the Product Description" FontWeight="ExtraBold"/>
              <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBox Text="{Binding CategoryName}" Watermark="Category Name..." Width="150"/>
                  <TextBox Text="{Binding Description}" Watermark="Description Contains..." Width="150"/>
              </StackPanel>
              <TextBlock Text="Filter By Stock and/or Deleted Status" FontWeight="ExtraBold"/>
              <StackPanel Orientation="Horizontal" Spacing="10">
				  <CheckBox IsChecked="{Binding InStock}" Content="In Stock Products"/>
                  <CheckBox IsChecked="{Binding IsDeleted}" Content="Deleted Products"/>
              </StackPanel>
              <Button Content="Apply Filters" Command="{Binding LoadProductsCommand}"/>
              <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}"/>
          </StackPanel>
          <StackPanel Grid.Row="1">
			  <TextBlock Text="Products (Select a product to see more information)" FontWeight="ExtraBold"/>
              <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}"/>
              <StackPanel>
				  <DataGrid ItemsSource="{Binding Products}"
                            SelectedItem="{Binding SelectedProduct}"
                            IsReadOnly="True"
                            GridLinesVisibility="All"
                            BorderThickness="1"
                            BorderBrush="Gray">
                      <DataGrid.Columns>
                          <DataGridTextColumn Header="Category Name" Binding="{Binding CategoryName}" Width="Auto"/>
                          <DataGridTextColumn Header="Product Name" Binding="{Binding Name}" Width="Auto"/>
                          <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="Auto"/>
                          <DataGridTextColumn Header="Stock Quantity" Binding="{Binding StockQuantity}" Width="Auto"/>
                          <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat={}{0:C}}" Width="Auto"/>
                          <DataGridTextColumn Header="Discount Percentage" Binding="{Binding DiscountPercentage}" Width="Auto"/>
                          <DataGridTextColumn Header="In Stock" Binding="{Binding IsInStock}" Width="Auto"/>
                          <DataGridTextColumn Header="Is Deleted" Binding="{Binding IsDeleted}" Width="Auto"/>
                          <DataGridTextColumn Header="Created At" Binding="{Binding CreatedAt}" Width="Auto"/>
                          <DataGridTextColumn Header="Updated At" Binding="{Binding UpdatedAt}" Width="Auto"/>
                      </DataGrid.Columns>
                  </DataGrid>
              </StackPanel>
              <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
				  <Button Content="Previous" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding HasPreviousPage}"/>
                  <TextBlock>
					  <Run Text="{Binding Page}"/>
                      <Run Text=" of "/>
                      <Run Text="{Binding TotalPages}"/>
                  </TextBlock>
                  <Button Content="Next" Command="{Binding NextPageCommand}" IsEnabled="{Binding HasNextPage}"/>
              </StackPanel>
          </StackPanel>
      </Grid>
  </ScrollViewer>
</UserControl>
