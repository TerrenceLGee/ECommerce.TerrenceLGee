<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ECommerce.AvaloniaClient.TerrenceLGee.ViewProductsForAdminView"
             xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
             xmlns:local="using:ECommerce.AvaloniaClient.TerrenceLGee"
             x:DataType="vm:ViewProductsForAdminViewModel">
  <StackPanel>
	  <local:ProductsAdminBaseView DataContext="{Binding}"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
		  <Button Content="Back To Product Page" Command="{Binding GoBackCommand}"/>
      </StackPanel>
  </StackPanel>
</UserControl>
