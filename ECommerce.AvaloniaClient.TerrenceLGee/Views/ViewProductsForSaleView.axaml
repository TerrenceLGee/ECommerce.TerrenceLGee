<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ECommerce.AvaloniaClient.TerrenceLGee.ViewProductsForSaleView"
			 xmlns:vm="using:ECommerce.AvaloniaClient.TerrenceLGee.ViewModels"
			 x:DataType="vm:ViewProductsForSaleViewModel">
	<StackPanel>
		<TextBlock Text="Products (Select a product to see information and add to cart)" FontWeight="ExtraBold"/>
		<ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}"/>
		<StackPanel>
			<DataGrid ItemsSource="{Binding Products}"
					  SelectedItem="{Binding SelectedProduct}"
					  IsReadOnly="True"
					  GridLinesVisibility="All"
					  BorderThickness="1"
					  BorderBrush="Gray">
				<DataGrid.Columns>
					<DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="Auto"/>
					<DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="Auto"/>
					<DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat={}{0:C}}" Width="Auto"/>
					<DataGridTextColumn Header="In Stock" Binding="{Binding IsInStock}" Width="Auto"/>
				</DataGrid.Columns>
			</DataGrid>
		</StackPanel>
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
			<Button Content="Previous" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding HasPreviousPage}"/>
			<TextBlock>
				<Run Text="{Binding Page}"/>
				<Run Text=" of "/>
				<Run Text="{Binding TotalPages}"/>
			</TextBlock>
			<Button Content="Next" Command="{Binding NextPageCommand}" IsEnabled="{Binding HasNextPage}"/>
		</StackPanel>
		<StackPanel>
			<Button Content="View Cart" Command="{Binding ViewCartCommand}" HorizontalAlignment="Center"/>
			<Button Content="Checkout" Command="{Binding CheckoutCommand}" HorizontalAlignment="Center"/>
		</StackPanel>
		<StackPanel>
			<Button Content="Back To Categories" Command="{Binding GoBackCommand}" HorizontalAlignment="Center"/>
		</StackPanel>
	</StackPanel>
</UserControl>
